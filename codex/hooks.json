{
  "description": "User-level Codex safety hooks.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$HOME/.codex/hooks/block_git_push.py\"",
            "timeout": 5,
            "statusMessage": "Checking git push policy"
          }
        ]
      }
    ]
  }
}
